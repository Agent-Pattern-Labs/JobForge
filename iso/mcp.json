{
  "servers": {
    "geometra": {
      "command": "npx",
      "args": ["--no-install", "job-forge", "mcp:geometra"],
      "env": {
        "GEOMETRA_STEALTH": "0",
        "GEOMETRA_BROWSER": "stock"
      }
    },
    "gmail": {
      "command": "npx",
      "args": ["-y", "@razroo/gmail-mcp"],
      "env": {
        "DISABLE_HTTP": "true"
      }
    },
    "state-trace": {
      "command": "state-trace-mcp",
      "env": {
        "STATE_TRACE_STORAGE_PATH": ".state-trace/memory.db",
        "STATE_TRACE_NAMESPACE": "job-forge",
        "STATE_TRACE_CAPACITY_LIMIT": "256"
      }
    }
  }
}
